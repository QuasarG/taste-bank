---
import Base from '../layouts/Base.astro';
import '../styles/pages.css';
import { listStyles, loadStyle } from '../lib/store';
import { getAllCategories, listCategories } from '../lib/categories';

const PAGE_SIZE = 8;
const all = listStyles().map((slug) => loadStyle(slug));
const catMap = getAllCategories();
const cats = listCategories();

const activeCat = Astro.url.searchParams.get('cat') ?? '';
const filtered = activeCat ? all.filter((s) => catMap[s.slug] === activeCat) : all;
const pageCount = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
const page = Math.min(Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10) || 1), pageCount);
const items = filtered.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);
const pageHref = (p: number) => `/collections?${new URLSearchParams({ ...(activeCat ? { cat: activeCat } : {}), page: String(p) })}`;
const catHref = (c: string) => (c ? `/collections?cat=${encodeURIComponent(c)}` : '/collections');
---

<Base title="All Style Collections" titleZh="全部风格" description="Browse every code-ready style pack in Taste Bank." wide>
  <main class="subpage">
    <div class="subpage-inner">
      <header class="subpage-head">
        <p class="eyebrow"><span data-ui-en>Taste Bank catalog</span><span data-ui-zh>Taste Bank 风格目录</span></p>
        <h1><span data-ui-en>All style collections</span><span class="cn-page-title" data-ui-zh>全部风格合集</span></h1>
        <p><span data-ui-en>Compare complete visual systems, then open a pack to copy its agent-ready prompt.</span><span data-ui-zh>比较完整的视觉系统，打开风格包即可复制交给 agent 的提示词。</span></p>
      </header>

      <nav class="cat-tabs" aria-label="Style categories">
        <a class:list={['cat-tab', { 'is-on': !activeCat }]} href="/collections"><span data-ui-en>All</span><span data-ui-zh>全部</span></a>
        {cats.map((c) => <a class:list={['cat-tab', { 'is-on': activeCat === c }]} href={catHref(c)}>{c}</a>)}
      </nav>

      {
        items.length > 0 ? (
          <div class="style-grid">
            {items.map((style) => (
              <a class="style-card" href={`/styles/${style.slug}`}>
                <img src={`/api/styles/${style.slug}/screenshot.png`} alt={`${style.meta.name} preview`} loading="lazy" />
                <span class="style-card-name">{style.meta.name}</span>
                <span class="style-card-meta">
                  {catMap[style.slug] && <span class="style-card-cat">{catMap[style.slug]}</span>}
                  <span>v{style.meta.version}</span>
                </span>
              </a>
            ))}
          </div>
        ) : (
          <p class="catalog-empty"><span data-ui-en>No style packs in this category yet.</span><span data-ui-zh>该分类下暂时没有已发布的风格包。</span></p>
        )
      }

      {
        pageCount > 1 && (
          <nav class="pager" aria-label="Pagination">
            {page > 1 ? <a class="pager-btn" href={pageHref(page - 1)}>← <span data-ui-en>Prev</span><span data-ui-zh>上一页</span></a> : <span class="pager-btn is-disabled" />}
            <span class="pager-info">{page} / {pageCount}</span>
            {page < pageCount ? <a class="pager-btn" href={pageHref(page + 1)}><span data-ui-en>Next</span><span data-ui-zh>下一页</span> →</a> : <span class="pager-btn is-disabled" />}
          </nav>
        )
      }

      <footer class="subpage-foot"><span><span data-ui-en>{all.length} published collections</span><span data-ui-zh>已发布 {all.length} 个合集</span></span><span>Taste Bank</span></footer>
    </div>
  </main>
</Base>
