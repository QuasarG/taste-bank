---
import Base from '../layouts/Base.astro';
import '../styles/home.css';
import { listStyles, loadStyle } from '../lib/store';

const styles = listStyles().map((slug) => loadStyle(slug));
const wheelItems = styles.map((style) => ({
      name: style.meta.name,
      image: `/api/styles/${style.slug}/screenshot.png`,
      alt: `${style.meta.name} style preview`,
      previewUrl: `/styles/${style.slug}/template.html`,
      summary: style.meta.summary,
      useCase: style.meta.useCase,
      mood: style.meta.mood.slice(0, 3).join(' / '),
      signature: style.meta.signature,
      author: style.meta.author,
      version: style.meta.version,
      createdAt: style.meta.createdAt,
      renderer: 'Astro / Interactive',
      href: `/styles/${style.slug}`,
    }));
const initialItem = wheelItems[0] ?? null;
const flowColumnA = [...wheelItems, ...wheelItems];
const reversedItems = [...wheelItems].reverse();
const flowColumnB = [...reversedItems, ...reversedItems];
---

<Base title="Taste Bank" titleZh="Taste Bank" description="Code-ready front-end styles for coding agents." wide>
  <div class="home" data-home>
    <section class="hero" id="top" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow"><span data-ui-en>Visual systems for coding agents</span><span data-ui-zh>面向 coding agent 的视觉系统</span></p>
        <h1 id="hero-title"><span data-ui-en>Front-end taste,<br /><em>ready to build.</em></span><span class="cn-home-title" data-ui-zh>前端品味，<br /><em>即刻构建。</em></span></h1>
        <p class="hero-intro"><span data-ui-en>Browse reusable visual systems, choose one, and hand its code-ready rules to your agent.</span><span data-ui-zh>浏览可复用的视觉系统，选定一种，将可执行的设计规则交给你的 agent。</span></p>
      </div>

      <div class="hero-flow" aria-label="A continuously moving stream of style previews">
        <div class="flow-meta"><span><span data-ui-en>Live style stream</span><span data-ui-zh>实时风格流</span></span><span>{String(wheelItems.length).padStart(2, '0')} <span data-ui-en>references</span><span data-ui-zh>个参考</span></span></div>
        {
          wheelItems.length > 0 ? (
            <div class="flow-viewport">
              <div class="flow-column">
                <div class="flow-track flow-track-a">
                  {flowColumnA.map((item) => <figure class="flow-card"><img src={item.image} alt={item.alt} /><figcaption>{item.name}</figcaption></figure>)}
                </div>
              </div>
              <div class="flow-column flow-column-offset">
                <div class="flow-track flow-track-b">
                  {flowColumnB.map((item) => <figure class="flow-card"><img src={item.image} alt={item.alt} /><figcaption>{item.name}</figcaption></figure>)}
                </div>
              </div>
            </div>
          ) : (
            <div class="flow-empty" role="status">
              <span aria-hidden="true">00</span>
              <p><span data-ui-en>Awaiting the first published style.</span><span data-ui-zh>等待首个风格投稿通过审核。</span></p>
            </div>
          )
        }
        <div class="flow-foot"><span><span data-ui-en>Rules</span><span data-ui-zh>规则</span></span><span>Tokens</span><span><span data-ui-en>Templates</span><span data-ui-zh>模板</span></span></div>
      </div>

      <a class="hero-arrow" href="#wheel-mode" aria-label="Enter style wheel mode">↓</a>
    </section>

    <section class:list={['wheel-mode', { 'is-empty': !initialItem }]} id="wheel-mode" aria-labelledby="wheel-mode-title" data-wheel-mode>
      <div class="wheel-preview" data-wheel-preview>
        <div class="wheel-preview-head">
          <span><span data-ui-en>Interactive preview</span><span data-ui-zh>交互预览</span></span>
          <span class="preview-spec"><i aria-hidden="true"></i>Astro <b>16:9</b></span>
          <span data-active-count>{initialItem ? '01' : '00'} / {String(wheelItems.length).padStart(2, '0')}</span>
        </div>
        {
          initialItem ? (
            <div class="wheel-preview-stage">
              <div class="wheel-preview-frame">
                <iframe src={initialItem.previewUrl} title={`${initialItem.name} interactive preview`} data-wheel-main loading="eager" sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"></iframe>
              </div>
            </div>
          ) : (
            <div class="wheel-preview-stage">
              <div class="wheel-preview-frame wheel-preview-empty"><span>1440 × 810</span><b>16:9</b></div>
            </div>
          )
        }
      </div>

      <aside class="wheel-info">
        <p class="eyebrow"><span data-ui-en>Taste Bank collection</span><span data-ui-zh>Taste Bank 风格合集</span></p>
        {
          initialItem ? (
            <>
              <h2 id="wheel-mode-title" data-wheel-name>{initialItem.name}</h2>
              <p class="wheel-summary" data-wheel-summary>{initialItem.summary}</p>
              <div class="wheel-byline">
                <span><small><span data-ui-en>By</span><span data-ui-zh>投稿者</span></small><b data-wheel-author>{initialItem.author}</b></span>
                <span><small><span data-ui-en>Version</span><span data-ui-zh>版本</span></small><b data-wheel-version>v{initialItem.version}</b></span>
                <span><small><span data-ui-en>Published</span><span data-ui-zh>发布日期</span></small><b data-wheel-date>{initialItem.createdAt}</b></span>
              </div>
              <dl class="wheel-details">
                <div><dt><span data-ui-en>Best for</span><span data-ui-zh>适用场景</span></dt><dd data-wheel-use>{initialItem.useCase}</dd></div>
                <div><dt><span data-ui-en>Character</span><span data-ui-zh>风格特征</span></dt><dd data-wheel-mood>{initialItem.mood}</dd></div>
                <div><dt><span data-ui-en>Signature</span><span data-ui-zh>设计标志</span></dt><dd data-wheel-signature>{initialItem.signature}</dd></div>
                <div><dt><span data-ui-en>Preview</span><span data-ui-zh>预览方式</span></dt><dd><span data-wheel-renderer>{initialItem.renderer}</span><span class="ratio-tag">16:9</span></dd></div>
              </dl>
              <div class="wheel-actions">
                <a class="text-link text-link-primary" href={initialItem.href} data-wheel-link><span data-ui-en>Full details</span><span data-ui-zh>完整详情</span> <span aria-hidden="true">↗</span></a>
                <a class="text-link" href={initialItem.previewUrl} target="_blank" rel="noreferrer" data-preview-open><span data-ui-en>Open preview</span><span data-ui-zh>单独打开预览</span> <span aria-hidden="true">↗</span></a>
              </div>
            </>
          ) : (
            <div class="wheel-empty-copy">
              <span aria-hidden="true">00</span>
              <h2 id="wheel-mode-title"><span data-ui-en>No published styles</span><span data-ui-zh>暂无已发布风格</span></h2>
              <p><span data-ui-en>Interactive previews and contributor details will appear here after review.</span><span data-ui-zh>投稿通过审核后，交互预览与投稿详情会显示在这里。</span></p>
            </div>
          )
        }
      </aside>

      <a class="wheel-back" href="#top" aria-label="Return to the showcase">↑</a>
      {initialItem && <button class="wheel-trigger" type="button" data-wheel-trigger aria-label="Open the style wheel" aria-controls="taste-wheel" aria-expanded="false" title="Turn the style wheel"><span aria-hidden="true">↕</span></button>}
    </section>

    {initialItem && <div class="taste-wheel" id="taste-wheel" data-taste-wheel aria-hidden="true">
      <a class="wheel-all" href="/collections"><span data-ui-en>All styles</span><span data-ui-zh>全部风格</span> <span aria-hidden="true">↗</span></a>
      {
        wheelItems.map((item, index) => (
          <button
            class="taste-wheel-card"
            type="button"
            data-wheel-card
            data-index={index}
            data-image={item.image}
            data-preview={item.previewUrl}
            data-name={item.name}
            data-alt={item.alt}
            data-summary={item.summary}
            data-use={item.useCase}
            data-mood={item.mood}
            data-signature={item.signature}
            data-author={item.author}
            data-version={item.version}
            data-date={item.createdAt}
            data-renderer={item.renderer}
            data-href={item.href}
            tabindex="-1"
          >
            <img src={item.image} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
            <span>{item.name}</span>
          </button>
        ))
      }
    </div>}
  </div>
</Base>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) document.documentElement.classList.add('motion-ready');

  const wheelMode = document.querySelector<HTMLElement>('[data-wheel-mode]');
  const wheel = document.querySelector<HTMLElement>('[data-taste-wheel]');
  const wheelTrigger = document.querySelector<HTMLButtonElement>('[data-wheel-trigger]');
  const wheelCards = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-wheel-card]'));
  const wheelPreview = document.querySelector<HTMLElement>('[data-wheel-preview]');
  const previewFrame = document.querySelector<HTMLElement>('.wheel-preview-frame');
  const wheelMain = document.querySelector<HTMLIFrameElement>('[data-wheel-main]');
  const activeName = document.querySelector<HTMLElement>('[data-wheel-name]');
  const activeCount = document.querySelector<HTMLElement>('[data-active-count]');
  const activeSummary = document.querySelector<HTMLElement>('[data-wheel-summary]');
  const activeUse = document.querySelector<HTMLElement>('[data-wheel-use]');
  const activeMood = document.querySelector<HTMLElement>('[data-wheel-mood]');
  const activeSignature = document.querySelector<HTMLElement>('[data-wheel-signature]');
  const activeAuthor = document.querySelector<HTMLElement>('[data-wheel-author]');
  const activeVersion = document.querySelector<HTMLElement>('[data-wheel-version]');
  const activeDate = document.querySelector<HTMLElement>('[data-wheel-date]');
  const activeRenderer = document.querySelector<HTMLElement>('[data-wheel-renderer]');
  const activeLink = document.querySelector<HTMLAnchorElement>('[data-wheel-link]');
  const previewOpen = document.querySelector<HTMLAnchorElement>('[data-preview-open]');
  const narrow = window.matchMedia('(max-width: 900px)');
  let active = 0;
  let wheelOpen = false;
  let wheelLock = 0;
  let settleTimer = 0;

  if (previewFrame) {
    const previewObserver = new ResizeObserver(([entry]) => {
      if (entry) previewFrame.style.setProperty('--preview-scale', String(entry.contentRect.width / 1440));
    });
    previewObserver.observe(previewFrame);
  }

  function layoutWheel() {
    wheelCards.forEach((card, index) => {
      const offset = index - active;
      const distance = Math.abs(offset);
      card.style.transform = `translate(${distance * 12 + distance * distance * 6}px, ${offset * 92}px) rotate(${offset * 5}deg) scale(${offset === 0 ? 1.06 : .9})`;
      card.style.opacity = String(Math.max(.2, 1 - distance * .22));
      card.style.zIndex = String(30 - distance);
      card.classList.toggle('is-active', offset === 0);
    });
  }

  function setWheelOpen(open: boolean) {
    if (!wheel) return;
    wheelOpen = open;
    wheel.classList.toggle('is-open', open);
    wheel.setAttribute('aria-hidden', String(!open));
    wheelCards.forEach((card) => { card.tabIndex = open ? 0 : -1; });
    wheelTrigger?.setAttribute('aria-expanded', String(open));
  }

  function applyActive() {
    const selected = wheelCards[active];
    if (!selected || !wheelMain || !wheelPreview) return;
    wheelPreview.classList.add('is-switching');
    window.setTimeout(() => {
      wheelMain.src = selected.dataset.preview ?? wheelMain.src;
      wheelMain.title = `${selected.dataset.name ?? 'Style'} interactive preview`;
      if (activeName) activeName.textContent = selected.dataset.name ?? '';
      if (activeCount) activeCount.textContent = `${String(active + 1).padStart(2, '0')} / ${String(wheelCards.length).padStart(2, '0')}`;
      if (activeSummary) activeSummary.textContent = selected.dataset.summary ?? '';
      if (activeUse) activeUse.textContent = selected.dataset.use ?? '';
      if (activeMood) activeMood.textContent = selected.dataset.mood ?? '';
      if (activeSignature) activeSignature.textContent = selected.dataset.signature ?? '';
      if (activeAuthor) activeAuthor.textContent = selected.dataset.author ?? '';
      if (activeVersion) activeVersion.textContent = `v${selected.dataset.version ?? ''}`;
      if (activeDate) activeDate.textContent = selected.dataset.date ?? '';
      if (activeRenderer) activeRenderer.textContent = selected.dataset.renderer ?? '';
      if (activeLink) activeLink.href = selected.dataset.href ?? '/collections';
      if (previewOpen) previewOpen.href = selected.dataset.preview ?? '/';
      wheelPreview.classList.remove('is-switching');
    }, prefersReduced ? 0 : 170);
  }

  function turnWheel(direction: 1 | -1) {
    if (wheelCards.length < 2) return;
    active = (active + direction + wheelCards.length) % wheelCards.length;
    layoutWheel();
  }

  wheelMode?.addEventListener('wheel', (event) => {
    if (narrow.matches || wheelCards.length < 2) return;
    const bounds = wheelMode.getBoundingClientRect();
    if (Math.abs(bounds.top - 66) > 18) return;
    event.preventDefault();
    setWheelOpen(true);
    const now = performance.now();
    if (now - wheelLock > 170) {
      wheelLock = now;
      turnWheel(event.deltaY >= 0 ? 1 : -1);
      applyActive();
    }
    window.clearTimeout(settleTimer);
    settleTimer = window.setTimeout(() => setWheelOpen(false), 1200);
  }, { passive: false });

  wheelTrigger?.addEventListener('click', () => setWheelOpen(!wheelOpen));
  wheelCards.forEach((card, index) => {
    card.addEventListener('click', () => {
      active = index;
      layoutWheel();
      applyActive();
      window.setTimeout(() => setWheelOpen(false), 260);
    });
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && wheelOpen) setWheelOpen(false);
  });
  const modeObserver = new IntersectionObserver((entries) => {
    if (!entries[0]?.isIntersecting) setWheelOpen(false);
  }, { threshold: .5 });
  if (wheelMode) modeObserver.observe(wheelMode);
  layoutWheel();
  applyActive();
</script>
