---
import Base from '../layouts/Base.astro';
import '../styles/focus.css';
import { listStyles, loadStyle } from '../lib/store';

const styles = listStyles().map((slug) => loadStyle(slug));

// 占位卡进轮盘，与真实风格共用一条翻牌序列
const SLOT_COLORS = ['#E9DCC8', '#D5E2EC', '#DCE8D5', '#EDD5DC', '#E8E3C8', '#DFD5EC', '#D5E8E4', '#ECD5C8'];
const TOTAL = 9;
const slots = Array.from({ length: Math.max(0, TOTAL - styles.length) }, (_, i) => ({
  n: i + 1,
  color: SLOT_COLORS[i % SLOT_COLORS.length],
}));
const firstSlug = styles.length > 0 ? styles[0].slug : null;
// slug → 模板页列表（翻页器用）
const templatesMap = Object.fromEntries(
  styles.map((s) => [
    s.slug,
    s.files.filter((f) => f.startsWith('templates/') && f.endsWith('.html')).sort().map((f) => f.replace('templates/', '')),
  ]),
);
---

<Base title="风格库" wide>
  <div class="focus" data-focus>
    <section class="stage-live">
      <div class="stage-body">
        {
          firstSlug && (
            <iframe class="live-frame" src={`/styles/${firstSlug}/template.html`} title="风格实时渲染" sandbox="" />
          )
        }
        <div class="wheel-trap" data-wheel-trap></div>
        <div class="stage-slot" data-stage-slot hidden={firstSlug !== null}>
          <span class="slot-big">SLOT 01</span>
        </div>
      </div>
      <div class="stage-pager" data-pager hidden>
        <button class="pager-btn" data-page-prev aria-label="上一页">◀</button>
        <span class="pager-label" data-page-label>1 / 1</span>
        <button class="pager-btn" data-page-next aria-label="下一页">▶</button>
      </div>
    </section>

    {
      styles.map((s, i) => (
        <aside class="info-col" data-info={s.slug} hidden={i !== 0}>
          <div class="info-card">
            <h1>
              {s.meta.name} <span class="ver">v{s.meta.version}</span>
            </h1>
            <div class="tags">
              {s.meta.mood.map((m) => (
                <span class="tag">{m}</span>
              ))}
            </div>
          </div>
          <div class="info-card">
            <h3>Signature</h3>
            <p>{s.meta.signature}</p>
            <h3>适用场景</h3>
            <p>{s.meta.useCase}</p>
            <h3>文案语气</h3>
            <p>{s.meta.rules.voice}</p>
          </div>
          <div class="info-card">
            <h3>Do</h3>
            <ul>
              {s.meta.rules.do.map((r) => (
                <li>{r}</li>
              ))}
            </ul>
            <h3>Don't</h3>
            <ul>
              {s.meta.rules.dont.map((r) => (
                <li>{r}</li>
              ))}
            </ul>
          </div>
          <div class="info-card actions">
            <button class="copy-btn" data-copy-url={`/api/styles/${s.slug}/skill.md`}>复制 SKILL.md</button>
            <button class="copy-btn" data-copy-url={`/api/styles/${s.slug}/tokens.css`}>复制 tokens.css</button>
            <a href={`/styles/${s.slug}`}>完整详情 →</a>
          </div>
        </aside>
      ))
    }

    <aside class="info-col" data-info="__slot" hidden={firstSlug !== null}>
      <div class="info-card">
        <h1>待收录 <span class="ver">placeholder</span></h1>
      </div>
      <div class="info-card">
        <h3>占位槽位</h3>
        <p>这是一个占位卡片，等新风格投稿后会自动替换为真实风格。滚轮翻牌，点卡片直接选定。</p>
      </div>
    </aside>

    <div class="wheel" data-wheel aria-hidden="true">
      <button class="wheel-expand" data-browse-open title="浏览全部风格">←<span>浏览全部</span></button>
      {
        styles.map((s) => (
          <div class="wheel-card" data-slug={s.slug}>
            <img src={`/api/styles/${s.slug}/screenshot.png`} alt={s.meta.name} loading="lazy" />
            <span class="wheel-name">{s.meta.name}</span>
          </div>
        ))
      }
      {
        slots.map((slot) => (
          <div class="wheel-card is-slot" data-slot={slot.n} data-color={slot.color}>
            <span class="wheel-slotcover" style={`--pc:${slot.color}`}>
              SLOT {String(slot.n).padStart(2, '0')}
            </span>
            <span class="wheel-name">待收录</span>
          </div>
        ))
      }
    </div>
  </div>

  <div class="browse" data-browse hidden>
    <div class="browse-head">
      <h1>全部风格</h1>
      <button class="copy-btn browse-close" data-browse-close>× 返回</button>
    </div>
    <div class="browse-grid">      {
        styles.map((s, i) => (
          <div class="style-card" data-goto={i} role="button" tabindex="0">
            <div class="preview">
              <img class="preview-img" src={`/api/styles/${s.slug}/screenshot.png`} alt={`${s.meta.name} 模板截图`} loading="lazy" />
            </div>
            <div class="style-info">
              <h2>
                {s.meta.name} <span class="ver">v{s.meta.version}</span>
              </h2>
              <p class="summary">{s.meta.summary}</p>
              <div class="tags">
                {s.meta.mood.map((m) => (
                  <span class="tag">{m}</span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
      {
        slots.map((slot, i) => (
          <div class="style-card is-placeholder" data-goto={styles.length + i} role="button" tabindex="0">
            <div class="preview placeholder-cover" style={`--pc:${slot.color}`}>
              <span class="slot-no">SLOT {String(slot.n).padStart(2, '0')}</span>
            </div>
            <div class="style-info">
              <h2>
                待收录 <span class="ver">placeholder</span>
              </h2>
              <p class="summary">占位卡片，新风格投稿后自动替换。</p>
              <div class="tags">
                <span class="tag">占位</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Base>

<script type="application/json" data-templates-json set:html={JSON.stringify(templatesMap)} />

<script>
  // 沉浸翻阅：滚轮召唤右缘轮盘，停滚 1200ms 收回并切换左区实时渲染。
  // 轮盘只听滚轮（无悬浮/点击检测）；多页模板用 ◀ ▶ 翻页器。
  const items = Array.from(document.querySelectorAll<HTMLElement>('.wheel-card'));
  const wheelEl = document.querySelector<HTMLElement>('[data-wheel]')!;
  const frame = document.querySelector<HTMLIFrameElement>('.live-frame');
  const slotCover = document.querySelector<HTMLElement>('[data-stage-slot]')!;
  const slotLabel = document.querySelector<HTMLElement>('.slot-big')!;
  const browseEl = document.querySelector<HTMLElement>('[data-browse]')!;
  const pagerEl = document.querySelector<HTMLElement>('[data-pager]')!;
  const pageLabel = document.querySelector<HTMLElement>('[data-page-label]')!;
  const narrow = window.matchMedia('(max-width: 900px)');
  const templatesMap: Record<string, string[]> = JSON.parse(
    document.querySelector('[data-templates-json]')!.textContent!,
  );

  let active = 0;
  let wheelOpen = false;
  let browseOpen = false;
  let wheelLock = 0;
  let settleTimer = 0;

  // 轮盘扇形布局：主视觉居中，其余上下散开、越远越透明
  function layoutWheel() {
    items.forEach((el, i) => {
      const k = i - active;
      const a = Math.abs(k);
      el.style.transform = `translate(${a * 12 + a * a * 6}px, ${k * 92}px) rotate(${k * 5}deg) scale(${k === 0 ? 1.06 : 0.9})`;
      el.style.opacity = String(Math.max(0.22, 1 - a * 0.22));
      el.style.zIndex = String(40 - a);
      el.classList.toggle('is-active', k === 0);
    });
  }

  // 模板翻页：重置到第一页并按文件数显示翻页器
  let pageIndex = 0;
  let curFiles: string[] = [];
  function setFramePage(slug: string) {
    curFiles = templatesMap[slug] ?? ['page.html'];
    pageIndex = 0;
    if (frame) frame.src = `/styles/${slug}/template.html?file=${curFiles[0]}`;
    pagerEl.hidden = curFiles.length <= 1;
    pageLabel.textContent = `1 / ${curFiles.length}`;
  }
  function turnPage(dir: 1 | -1) {
    if (curFiles.length <= 1) return;
    pageIndex = (pageIndex + dir + curFiles.length) % curFiles.length;
    const el = items[active];
    if (frame && el.dataset.slug) {
      frame.src = `/styles/${el.dataset.slug}/template.html?file=${curFiles[pageIndex]}`;
    }
    pageLabel.textContent = `${pageIndex + 1} / ${curFiles.length}`;
  }
  document.querySelector('[data-page-prev]')!.addEventListener('click', () => turnPage(-1));
  document.querySelector('[data-page-next]')!.addEventListener('click', () => turnPage(1));

  // 主视觉落地：切 iframe / 占位封面与信息栏（纯 DOM 交换，无动画）
  function doSwap() {
    const el = items[active];
    const slug = el.dataset.slug;
    if (slug) {
      slotCover.hidden = true;
      if (frame) {
        frame.hidden = false;
        if (!frame.src.includes(`/styles/${slug}/template.html`)) setFramePage(slug);
      }
    } else {
      if (frame) frame.hidden = true;
      pagerEl.hidden = true;
      slotCover.hidden = false;
      slotCover.style.setProperty('--pc', el.dataset.color ?? '#E5E5E0');
      slotLabel.textContent = `SLOT ${(el.dataset.slot ?? '').padStart(2, '0')}`;
    }
    document.querySelectorAll<HTMLElement>('.info-col').forEach((a) => {
      a.hidden = a.dataset.info !== (slug ?? '__slot');
    });
    document.title = `${el.querySelector('.wheel-name')?.textContent ?? ''} · Style Lab`;
  }

  // 带方向切换：旧内容滑出渐隐，新内容从另一侧滑入（方向跟翻牌走）
  let switching = false;
  async function applyActive(dir: 1 | -1) {
    if (switching) {
      doSwap();
      return;
    }
    switching = true;
    const stage = document.querySelector<HTMLElement>('.stage-live')!;
    const curAside = document.querySelector<HTMLElement>('.info-col:not([hidden])');
    for (const el of [stage, curAside]) {
      if (!el) continue;
      el.style.transform = `translateY(${-18 * dir}px)`;
      el.style.opacity = '0';
    }
    await new Promise((r) => setTimeout(r, 170));
    doSwap();
    const nextAside = document.querySelector<HTMLElement>('.info-col:not([hidden])');
    for (const el of [stage, curAside, nextAside]) {
      if (!el) continue;
      el.style.transition = 'none';
      el.style.transform = `translateY(${18 * dir}px)`;
      el.style.opacity = '0';
    }
    void stage.offsetWidth; // 强制 reflow，让进入起点生效
    for (const el of [stage, curAside, nextAside]) {
      if (!el) continue;
      el.style.transition = '';
      el.style.transform = '';
      el.style.opacity = '';
    }
    switching = false;
  }

  function openWheel() {
    if (!wheelOpen) {
      wheelOpen = true;
      wheelEl.classList.add('is-open');
      wheelEl.setAttribute('aria-hidden', 'false');
    }
  }
  function closeWheel() {
    wheelOpen = false;
    wheelEl.classList.remove('is-open');
    wheelEl.setAttribute('aria-hidden', 'true');
  }

  // 滚轮翻牌：全览网格内不拦截，其余区域一律映射给轮盘（外层页面锁死一页）
  let lastDir: 1 | -1 = 1;
  window.addEventListener(
    'wheel',
    (e) => {
      if (browseOpen || narrow.matches) return;
      e.preventDefault();
      openWheel();
      const now = performance.now();
      if (now - wheelLock > 170) {
        wheelLock = now;
        lastDir = e.deltaY > 0 ? 1 : -1;
        active = (active + lastDir + items.length) % items.length;
        layoutWheel();
      }
      clearTimeout(settleTimer);
      settleTimer = window.setTimeout(() => {
        closeWheel();
        applyActive(lastDir);
      }, 1200);
    },
    { passive: false },
  );

  // 轮盘只听滚轮：不做悬浮聚焦、不做点击选定，避免误触跳界面

  // 全览网格
  function openBrowse() {
    browseOpen = true;
    browseEl.hidden = false;
  }
  function closeBrowse() {
    browseOpen = false;
    browseEl.hidden = true;
  }

  // 滚轮捕获层：按下放行让 iframe 可交互，移出舞台后恢复捕获
  const trap = document.querySelector<HTMLElement>('[data-wheel-trap]')!;
  const stageLive = document.querySelector<HTMLElement>('.stage-live')!;
  trap.addEventListener('mousedown', () => {
    trap.style.pointerEvents = 'none';
  });
  stageLive.addEventListener('mouseleave', () => {
    trap.style.pointerEvents = 'auto';
  });
  document.querySelector('[data-browse-open]')!.addEventListener('click', openBrowse);
  document.querySelector('[data-browse-close]')!.addEventListener('click', closeBrowse);
  document.querySelectorAll<HTMLElement>('[data-goto]').forEach((el) => {
    el.addEventListener('click', () => {
      const goto = Number(el.dataset.goto);
      const dir: 1 | -1 = goto >= active ? 1 : -1;
      active = goto;
      closeBrowse();
      applyActive(dir);
    });
  });
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && browseOpen) closeBrowse();
  });

  // 复制按钮：按需拉取文本再写剪贴板
  document.querySelectorAll<HTMLButtonElement>('[data-copy-url]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const res = await fetch(btn.dataset.copyUrl!);
      await navigator.clipboard.writeText(await res.text());
      const old = btn.textContent;
      btn.textContent = '已复制 ✓';
      setTimeout(() => {
        btn.textContent = old;
      }, 1500);
    });
  });

  layoutWheel();
</script>
